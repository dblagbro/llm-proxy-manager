# LLM Proxy Manager - Environment Configuration
# Copy this file to .env and configure your settings

# Server Configuration
NODE_ENV=production
PORT=3000

# Session Secret (generate a random string for production)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# ============================================================================
# Circuit Breaker Configuration
# ============================================================================
# Number of consecutive failures before opening circuit breaker
CIRCUIT_BREAKER_THRESHOLD=3

# Time (ms) circuit breaker stays open before attempting recovery
CIRCUIT_BREAKER_TIMEOUT=60000

# Time (ms) to test provider in half-open state
CIRCUIT_BREAKER_HALFOPEN=30000

# Number of successes needed to close circuit breaker
CIRCUIT_BREAKER_SUCCESS=2

# ============================================================================
# Provider Timeout Configuration (milliseconds)
# ============================================================================
ANTHROPIC_TIMEOUT=30000
GOOGLE_TIMEOUT=30000
OPENAI_TIMEOUT=30000
GROK_TIMEOUT=30000
OLLAMA_TIMEOUT=60000
VERTEX_TIMEOUT=30000
COMPATIBLE_TIMEOUT=30000

# ============================================================================
# Cluster Configuration
# ============================================================================
# Enable cluster mode for multi-instance deployment
CLUSTER_ENABLED=false

# Unique identifier for this node
CLUSTER_NODE_ID=node1

# Human-readable name for this node
CLUSTER_NODE_NAME="LLM Proxy Node 1"

# URL where this node can be reached (for peer discovery)
CLUSTER_NODE_URL=http://localhost:3000

# Shared secret for cluster authentication (must be same on all nodes)
CLUSTER_SYNC_SECRET=change-this-to-a-shared-secret

# Comma-separated list of peer nodes (format: id:url,id:url)
# Example: CLUSTER_PEERS=node2:http://192.168.1.102:3000,node3:http://192.168.1.103:3000
CLUSTER_PEERS=

# Sync activity log between cluster nodes (can generate lots of traffic)
CLUSTER_SYNC_ACTIVITY_LOG=false

# ============================================================================
# SMTP Email Notifications
# ============================================================================
# Enable email alerts for critical failures
SMTP_ENABLED=false

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Authentication
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Email Settings
SMTP_FROM=llm-proxy@example.com
SMTP_TO=admin@example.com
SMTP_SUBJECT_PREFIX=[LLM Proxy Alert]

# Alert Configuration
SMTP_MIN_SEVERITY=WARNING
ALERT_THROTTLE_MINUTES=15

# ============================================================================
# Optional: Pre-configure Provider API Keys
# ============================================================================
# These can also be configured through the Web UI after startup

# Anthropic Claude API Keys
#ANTHROPIC_KEY_1=sk-ant-api03-your-key-here
#ANTHROPIC_KEY_2=sk-ant-api03-your-other-key-here

# Google Gemini API Keys
#GOOGLE_API_KEY_1=AIzaSy-your-key-here
#GOOGLE_API_KEY_2=AIzaSy-your-other-key-here

# Google Vertex AI
#GOOGLE_PROJECT_ID=your-gcp-project-id
#GOOGLE_API_KEY_VERTEX=your-vertex-api-key-or-oauth-token

# OpenAI API Keys
#OPENAI_KEY_1=sk-your-openai-key-here

# Grok (xAI) API Keys
#GROK_KEY_1=your-grok-api-key-here
