# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, single-node):
DATABASE_URL=sqlite+aiosqlite:////app/data/llmproxy.db
# PostgreSQL (cluster mode):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/llmproxy

# ── Redis (optional — in-memory fallback when not set) ───────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_SEC=60
CIRCUIT_BREAKER_HALFOPEN_SEC=30
CIRCUIT_BREAKER_SUCCESS_NEEDED=2
HOLD_DOWN_SEC=120

# ── CoT-E Pipeline ────────────────────────────────────────────────────────────
COT_MAX_ITERATIONS=1
COT_QUALITY_THRESHOLD=6
COT_CRITIQUE_MAX_TOKENS=200
COT_PLAN_MAX_TOKENS=400
COT_SESSION_TTL_SEC=1800
COT_SESSION_MAX_ANALYSES=3

# ── Cluster Mode ──────────────────────────────────────────────────────────────
CLUSTER_ENABLED=false
# CLUSTER_NODE_ID=node1
# CLUSTER_NODE_NAME=Node 1
# CLUSTER_NODE_URL=http://node1.example.com:3000
# CLUSTER_PEERS=node2:http://node2:3000,node3:http://node3:3000
# CLUSTER_SYNC_SECRET=shared-hmac-secret

# ── Email Notifications ───────────────────────────────────────────────────────
SMTP_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=llm-proxy@example.com
# SMTP_TO=admin@example.com
