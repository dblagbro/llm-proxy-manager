+// API Key validation middleware
+function validateApiKey(req, res, next) {
+  // Exempt certain paths
+  if (req.path === '/health' || req.path.startsWith('/api/') || req.path === '/') {
+    return next();
+  }
+
+  const apiKey = req.headers['x-api-key'] ||
+                 req.headers.authorization?.replace('Bearer ', '');
+
+  if (!apiKey) {
+    return res.status(401).json({ error: 'API key required' });
+  }
+
+  const clientKey = config.clientApiKeys.find(k => k.key === apiKey && k.enabled);
+  if (!clientKey) {
+    return res.status(401).json({ error: 'Invalid or disabled API key' });
+  }
+
+  req.clientKey = clientKey;
+  clientKey.lastUsed = new Date().toISOString();
+  next();
+}
