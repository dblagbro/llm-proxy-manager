+// Client API Key Management
+app.get('/api/client-keys', (req, res) => {
+  res.json(config.clientApiKeys || []);
+});
+
+app.post('/api/client-keys', (req, res) => {
+  const { name } = req.body;
+  if (!name) {
+    return res.status(400).json({ error: 'Name required' });
+  }
+
+  const key = {
+    id: `key-${Date.now()}`,
+    key: `llm-proxy-${crypto.randomBytes(32).toString('hex')}`,
+    name,
+    created: new Date().toISOString(),
+    lastUsed: null,
+    requests: 0,
+    enabled: true
+  };
+
+  if (!config.clientApiKeys) config.clientApiKeys = [];
+  config.clientApiKeys.push(key);
+  saveConfig();
+
+  res.json(key);
+});
+
+app.delete('/api/client-keys/:id', (req, res) => {
+  const { id } = req.params;
+  const index = config.clientApiKeys.findIndex(k => k.id === id);
+
+  if (index === -1) {
+    return res.status(404).json({ error: 'Key not found' });
+  }
+
+  config.clientApiKeys.splice(index, 1);
+  saveConfig();
+  res.json({ success: true });
+});
+
+app.patch('/api/client-keys/:id', (req, res) => {
+  const { id } = req.params;
+  const { enabled, name } = req.body;
+  const key = config.clientApiKeys.find(k => k.id === id);
+
+  if (!key) {
+    return res.status(404).json({ error: 'Key not found' });
+  }
+
+  if (enabled !== undefined) key.enabled = enabled;
+  if (name) key.name = name;
+
+  saveConfig();
+  res.json(key);
+});
+
